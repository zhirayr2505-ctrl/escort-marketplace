# --- WebApp (Next.js / Vercel) — префикс NEXT_PUBLIC_ доступен в браузере
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_TELEGRAM_BOT_NAME=

# Telegram Login Widget (публичный домен бота из @BotFather)
# NEXT_PUBLIC_TELEGRAM_BOT_ID=

# --- Telegram bot (Render) — не публиковать
TELEGRAM_BOT_TOKEN=
WEBAPP_URL=https://your-app.vercel.app
ADMIN_TELEGRAM_ID=
# Личный чат или группа: куда пересылать «Стать моделью» и алерты
ADMIN_CHAT_ID=

# Supabase service role — только на сервере бота / API, не в клиенте
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# USDT (ручная проверка скриншотов)
USDT_WALLET_MAIN=
USDT_WALLET_DEPOSIT_LABEL=залог

# Регистрация / подписка (суммы можно дублировать из админки позже)
REGISTRATION_FEE_USDT=50
MONTHLY_FEE_USDT=50
