# Шаблон БЕЗ секретов — коммитится в Git. Реальные ключи: web/.env.local и bot/.env
#
# Где взять Supabase: Dashboard → Project Settings → Data API / API Keys
#   Project URL → NEXT_PUBLIC_SUPABASE_URL и SUPABASE_URL
#   anon / publishable → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   service_role → SUPABASE_SERVICE_ROLE_KEY

# --- Next.js → web/.env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Username бота из @BotFather (без @) — для Telegram Login Widget на /login
NEXT_PUBLIC_TELEGRAM_BOT_NAME=cute_am_bot
# Тот же токен, что у бота — только сервер, для проверки подписи виджета
TELEGRAM_BOT_TOKEN=

# Тот же service_role из Supabase (только сервер, без префикса NEXT_PUBLIC) — для главной
SUPABASE_SERVICE_ROLE_KEY=

# Сессия пользователя после Telegram (опционально; иначе берётся ADMIN_SESSION_SECRET)
USER_SESSION_SECRET=

# Админ-панель /register + /admin (придумай длинные случайные строки)
ADMIN_PANEL_PASSWORD=1234567890
ADMIN_SESSION_SECRET=

# --- Бот → bot/.env
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TELEGRAM_BOT_TOKEN=
WEBAPP_URL=http://localhost:3000
ADMIN_TELEGRAM_ID=
ADMIN_CHAT_ID=

USDT_WALLET_MAIN=
USDT_WALLET_DEPOSIT_LABEL=залог
REGISTRATION_FEE_USDT=50
MONTHLY_FEE_USDT=50
